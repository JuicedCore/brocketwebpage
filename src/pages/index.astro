---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Replace this with your actual Supabase URL
const DOWNLOAD_URL = "https://muzunixvfbxrzpduahtg.supabase.co/storage/v1/object/sign/app-dist/app-arm64-v8a-release.apk?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV9lNzMxOWQ4Yi0wNjk2LTQ4NmQtYWM4Yi0zOTZmNzBiYWI0ODIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJhcHAtZGlzdC9hcHAtYXJtNjQtdjhhLXJlbGVhc2UuYXBrIiwiaWF0IjoxNzczOTI1Mjg2LCJleHAiOjE3NzQ1MzAwODZ9.kpp6IWDABbkQsc9l79_OEptheKROjZQL2JAuUZDcZ9A";
const IOS_REDIRECT_URL = "https://www.youtube.com/watch?v=J9NQFACZYEU&list=RDJ9NQFACZYEU&start_radio=1";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Get Brocket" description="CHAD does what CHAD wants." />
		<style>
			main {
				width: 100%;
				max-width: 900px;
				margin: auto;
				padding: 3em 1em;
				text-align: center;
			}
			.hero {
				background: #1e1e1e;
				padding: 4rem 2rem;
				border-radius: 24px;
				border: 1px solid #333;
				box-shadow: 0 20px 40px rgba(0,0,0,0.4);
			}
			h1 {
				font-size: 4rem;
				margin: 0;
				background: linear-gradient(to right, #3ecf8e, #34b27b);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				text-transform: uppercase;
				letter-spacing: -2px;
			}
			p.tagline {
				font-size: 1.5rem;
				color: #888;
				margin-top: 0.5rem;
			}
			.chad-motto {
				font-style: italic;
				font-weight: bold;
				margin: 2rem 0;
				color: #fff;
				font-size: 1.2rem;
			}
			.download-btn {
				display: inline-block;
				background: #3ecf8e;
				color: #000;
				padding: 1.2rem 3rem;
				border-radius: 12px;
				font-weight: 900;
				font-size: 1.4rem;
				text-decoration: none;
				transition: transform 0.2s, box-shadow 0.2s;
				margin-top: 1rem;
			}
			.download-btn:hover {
				transform: scale(1.05);
				box-shadow: 0 0 30px rgba(62, 207, 142, 0.4);
			}
			.warning {
				margin-top: 2rem;
				font-size: 0.9rem;
				color: #555;
			}
.android {
				background: #3ecf8e;
				color: #000;
			}
			/* iOS Silver/Dark */
			.ios {
				background: #333;
				color: #fff;
				border: 1px solid #444;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">

				<h1> Brocket </h1>
				<p class="tagline">For the Brotherhood. No BS. </p>
				
				<div class="chad-motto">
					"CHAD does what CHAD wants."

				</div>

				<a 
  href={DOWNLOAD_URL} 
  id="download-link" 
  download="Brocket.apk" 
  class="download-btn android"
>
					DOWNLOAD APK (ARM64)
				</a>
<a href={IOS_REDIRECT_URL} class="download-btn ios">
						DOWNLOAD FOR IOS
					</a>
				<div class="chad-motto">
					* If Chrome cries about "harmful files", and keeps yapping, ignore it. <br> 
					CHAD knows what's best.
				</div>
<div class="warning">
					* iOS: Apple is too restrictive for the Brotherhood. Enjoy the tunes.
				</div>
			</section>
		</main>
		<Footer />
	</body>

</html>
