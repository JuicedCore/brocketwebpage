---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Replace this with your actual Supabase URL
const DOWNLOAD_URL = "https://your-project.supabase.co/storage/v1/object/public/app-dist/app-arm64-v8a-release.apk";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Get Brocket" description="CHAD does what CHAD wants." />
		<style>
			main {
				width: 100%;
				max-width: 900px;
				margin: auto;
				padding: 3em 1em;
				text-align: center;
			}
			.hero {
				background: #1e1e1e;
				padding: 4rem 2rem;
				border-radius: 24px;
				border: 1px solid #333;
				box-shadow: 0 20px 40px rgba(0,0,0,0.4);
			}
			h1 {
				font-size: 4rem;
				margin: 0;
				background: linear-gradient(to right, #3ecf8e, #34b27b);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				text-transform: uppercase;
				letter-spacing: -2px;
			}
			p.tagline {
				font-size: 1.5rem;
				color: #888;
				margin-top: 0.5rem;
			}
			.chad-motto {
				font-style: italic;
				font-weight: bold;
				margin: 2rem 0;
				color: #fff;
				font-size: 1.2rem;
			}
			.download-btn {
				display: inline-block;
				background: #3ecf8e;
				color: #000;
				padding: 1.2rem 3rem;
				border-radius: 12px;
				font-weight: 900;
				font-size: 1.4rem;
				text-decoration: none;
				transition: transform 0.2s, box-shadow 0.2s;
				margin-top: 1rem;
			}
			.download-btn:hover {
				transform: scale(1.05);
				box-shadow: 0 0 30px rgba(62, 207, 142, 0.4);
			}
			.warning {
				margin-top: 2rem;
				font-size: 0.9rem;
				color: #555;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Brocket</h1>
				<p class="tagline">For the Brotherhood. No BS. </p>
				
				<div class="chad-motto">
					"CHAD does what CHAD wants."
				</div>

				<a href={DOWNLOAD_URL} class="download-btn">
					DOWNLOAD APK (ARM64)
				</a>

				<div class="warning">
					* If Chrome cries about "harmful files", and keeps yapping, ignore it. <br> 
					CHAD knows what's best.
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
